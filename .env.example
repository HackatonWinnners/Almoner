# --- Gemini brain (@google/genai) ---
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Circle Agent Wallet (Base Sepolia testnet) ---
# Auth is via the Circle CLI's interactive login (NOT a pasted key):
#   CIRCLE_ACCEPT_TERMS=1 circle wallet login <email> --type agent --testnet --init
# The session is stored locally; the live adapter spawns `circle` and reuses it.
# These addresses parameterize `npm run live` (defaults baked into live-demo.ts):
ALMONER_TREASURY=0xd1345b0f3ce28fbc87388bd98e388413e5b81945
ALMONER_USDC=0x036cbd53842c5426634e7929541ec2318f3dcf7e
ALMONER_RECIPIENT=0x79fde131eec4fdea04316d75ce1b79040bffb9c5
CIRCLE_ACCEPT_TERMS=1

# --- x402 marketplace (paid screening / image verification) ---
# Paid per-call from the funded agent wallet via `circle services pay`.
X402_ENDPOINT=
X402_API_KEY=

# --- Runtime mode ---
# mock  = fully offline deterministic stubs (default, used by `npm run demo`)
# live  = call real Circle / x402 / Gemini services
ALMONER_MODE=mock
