# --- Claude Agent SDK ---
ANTHROPIC_API_KEY=

# --- Circle Agent Wallet (Arc testnet) ---
# Filled once the program treasury wallet is provisioned via Circle CLI.
CIRCLE_API_KEY=
CIRCLE_WALLET_ID=
CIRCLE_ENTITY_SECRET=
CIRCLE_CHAIN=ARC-TESTNET

# --- x402 marketplace (paid screening / image verification) ---
X402_ENDPOINT=
X402_API_KEY=

# --- Runtime mode ---
# mock  = fully offline deterministic stubs (default, used by `npm run demo`)
# live  = call real Circle / x402 / Claude services
ALMONER_MODE=mock
